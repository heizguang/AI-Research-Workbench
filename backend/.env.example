# ===== 多厂商 LLM 故障转移（按逗号顺序尝试，前者不可用自动切换）=====
# 不配置 LLM_PROVIDERS 时退回单厂商兼容模式（用下方 OPENAI_* / SMART_LLM 等）
LLM_PROVIDERS=openai,agnes

# 厂商1：openai（主用）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_FAST_LLM=mimo-v2.5
OPENAI_SMART_LLM=mimo-v2.5-pro
OPENAI_STRATEGIC_LLM=mimo-v2.5-pro

# 厂商2：agnes（备用，填入 API Key 后生效）
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_API_KEY=your_agnes_api_key_here
AGNES_FAST_LLM=agnes-2.0-flash
AGNES_SMART_LLM=agnes-2.0-flash
AGNES_STRATEGIC_LLM=agnes-2.0-flash

SMART_TOKEN_LIMIT=12000
TOTAL_WORDS=3000

# 嵌入模型配置
EMBEDDING=openai:text-embedding-ada-002
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# 搜索配置
TAVILY_API_KEY=your_tavily_api_key_here
RETRIEVER=tavily

# 语言配置
LANGUAGE=chinese

# 向量存储配置
# 可选值: milvus, faiss, file
VECTOR_STORE=file
MILVUS_HOST=localhost
MILVUS_PORT=19530

# 应用配置
APP_ENV=development
APP_DEBUG=true
APP_PORT=8080
FRONTEND_PORT=3080

# CORS 允许的域名（逗号分隔），留空则使用默认白名单
# CORS_ORIGINS=http://localhost:3000,http://localhost:3080

# 数据目录
UPLOAD_DIR=./data/uploads
EXPORT_DIR=./data/exports
PPT_DIR=./data/ppt
MEMORY_DIR=./data/memory

# ===== Agent Loop 配置 =====
AGENT_LOOP_MAX_LOOPS=20
AGENT_LOOP_MAX_TOKENS=100000
AGENT_LOOP_CONTEXT_WINDOW=10
AGENT_LOOP_SUMMARY_THRESHOLD=80000
AGENT_LOOP_MAX_CONCURRENT=5
AGENT_LOOP_TOOL_TIMEOUT=60
AGENT_LOOP_MAX_TOOL_RETRIES=2
AGENT_LOOP_MAX_ASK_USER=3
